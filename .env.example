# --- Phase 1 CLI + Phase 2 web ---
ANTHROPIC_API_KEY=      # required
YOUTUBE_API_KEY=        # required, Data API v3
MAX_VIDEOS=100          # hard cap per run
MAX_RESEARCH_ITERATIONS=8   # per app, hard cap on agent loop

# --- Phase 1 CLI only ---
DB_PATH=./data/appscout.db

# --- Phase 2 web app only ---
DATABASE_URL=           # Postgres (Neon / Vercel Postgres) connection string
# INNGEST_SIGNING_KEY=  # set automatically by the Inngest Vercel integration
# INNGEST_EVENT_KEY=    # (local dev uses the Inngest dev server, no keys needed)
